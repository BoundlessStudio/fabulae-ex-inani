{
    "compilerOptions": {
        "target": "es2022",
        "allowSyntheticDefaultImports": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "typeRoots": ["./node_modules/@types"],
        "noEmit": true,
        "allowJs": true,
        "checkJs": true,
        "lib": [ "es2022" ]
    },
    "include": ["src/**/*.ts", "dependencies/dual-mesh/**/*.ts", "scripts/**/*.mjs"],
    "exclude": ["node_modules", "build", "dist", "output", "public/build"]
}
