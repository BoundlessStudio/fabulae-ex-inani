{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": false,
        "lib": ["ES2022"],
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["./*.ts", "./dual-mesh/**/*.ts"],
    "exclude": ["node_modules", "build", "dist", "public/build"]
}
